# Required
CANVAS_API_TOKEN=          # bCourses → Profile → Settings → + New Access Token
TELEGRAM_BOT_TOKEN=        # @BotFather on Telegram → /newbot
TELEGRAM_USER_ID=          # @userinfobot on Telegram → your numeric ID
GEMINI_API_KEY=            # https://aistudio.google.com/apikey

# Optional
TODOIST_API_TOKEN=         # Settings → Integrations → Developer → API Token
CANVAS_BASE_URL=https://bcourses.berkeley.edu/api/v1
OBSIDIAN_VAULT=./obsidian  # Path to Obsidian vault directory
GMAIL_CREDENTIALS=./.gmail-mcp  # Path to Gmail OAuth credentials directory
