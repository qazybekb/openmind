---
---
<section id="features" class="section">
  <div class="container">
    <div class="text-center mb-20 fade-in">
      <div class="badge mb-5">Features</div>
      <h2 class="text-3xl md:text-5xl font-bold text-text-primary tracking-tight mb-5">
        38 tools.<br/><span class="text-cal-gold">One study buddy.</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        Not a generic chatbot. A personalized assistant that knows your courses, your goals, and your campus.
      </p>
    </div>

    <!-- Row 1: Core academic tools -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-5">
      <div class="card glow fade-in fade-in-delay-1">
        <div class="text-2xl mb-4">📚</div>
        <h3 class="text-text-primary font-semibold mb-2">Smart Deadlines</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Sorted by urgency &times; grade weight. A 30% midterm due Friday outranks a 1% quiz due tomorrow.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-2">
        <div class="text-2xl mb-4">🎓</div>
        <h3 class="text-text-primary font-semibold mb-2">Guided Learning</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Interactive teach mode from your actual lectures. Asks real questions, checks understanding, connects to rubrics.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-3">
        <div class="text-2xl mb-4">📄</div>
        <h3 class="text-text-primary font-semibold mb-2">PDF Summarizer</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Downloads lecture slides and papers from bCourses, extracts text, and summarizes key concepts.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-4">
        <div class="text-2xl mb-4">📊</div>
        <h3 class="text-text-primary font-semibold mb-2">Grade Calculator</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          &ldquo;What do I need for an A?&rdquo; &mdash; calculates from assignment weights, shows the math.
        </p>
      </div>
    </div>

    <!-- Row 2: Personalization + campus -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-5">
      <div class="card glow fade-in fade-in-delay-1">
        <div class="text-2xl mb-4">🧠</div>
        <h3 class="text-text-primary font-semibold mb-2">Personalized Profile</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Import your resume. Set career goals. OpenMind tailors every response to your major, interests, and skills.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-2">
        <div class="text-2xl mb-4">🔍</div>
        <h3 class="text-text-primary font-semibold mb-2">Skill Gap Analysis</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Compares your resume against career goals. &ldquo;You need UX skills for PM roles &mdash; take INFO 214.&rdquo;
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-3">
        <div class="text-2xl mb-4">📘</div>
        <h3 class="text-text-primary font-semibold mb-2">Course Catalog</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          11,000+ Berkeley courses searchable by subject, level, or keyword. Undergrad and graduate.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-4">
        <div class="text-2xl mb-4">📅</div>
        <h3 class="text-text-primary font-semibold mb-2">Campus Events</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Live events from events.berkeley.edu. Library hours. Study room booking links.
        </p>
      </div>
    </div>

    <!-- Row 3: Integrations -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      <div class="card glow fade-in fade-in-delay-1">
        <div class="text-2xl mb-4">📱</div>
        <h3 class="text-text-primary font-semibold mb-2">Telegram Alerts</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Chat via Telegram. Background alerts every 3 hours: deadlines, grade changes, new announcements.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-2">
        <div class="text-2xl mb-4">💬</div>
        <h3 class="text-text-primary font-semibold mb-2">Slack</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Search and read your course Slack channels. &ldquo;What did the TA say about the midterm?&rdquo;
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-3">
        <div class="text-2xl mb-4">📆</div>
        <h3 class="text-text-primary font-semibold mb-2">Google Calendar</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Add deadlines to your calendar. Block study time. Bulk-sync all Canvas assignments.
        </p>
      </div>
      <div class="card glow fade-in fade-in-delay-4">
        <div class="text-2xl mb-4">📧</div>
        <h3 class="text-text-primary font-semibold mb-2">Gmail + Todoist + Obsidian</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Professor emails. Task sync. Knowledge graph. Connect what you need, skip the rest.
        </p>
      </div>
    </div>

  </div>
</section>
