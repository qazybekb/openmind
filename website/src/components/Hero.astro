---
---
<section class="pt-28 pb-20 md:pt-36 md:pb-28 relative">
  <!-- Subtle radial glow -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 40% at 50% 15%, rgba(253,181,21,0.06), transparent);"></div>

  <div class="container text-center relative z-10">

    <!-- Logo -->
    <div class="mb-8 flex justify-center">
      <img src="/logo.svg" alt="OpenMind logo" class="w-24 h-24 md:w-28 md:h-28 drop-shadow-[0_0_30px_rgba(253,181,21,0.3)]" />
    </div>

    <!-- Product name -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tight mb-5">
      <span class="text-text-primary">Open</span><span class="text-cal-gold">Mind</span>
    </h1>

    <!-- Tagline -->
    <p class="text-sm md:text-base uppercase tracking-[0.25em] text-text-muted font-medium mb-8">
      The AI study buddy that knows your campus.
    </p>

    <!-- Description -->
    <p class="text-lg md:text-xl text-text-body max-w-2xl mx-auto mb-12 leading-relaxed">
      Connects to bCourses, reads your lectures, tracks your deadlines, and talks like a Bear.<br class="hidden md:block"/>
      Any LLM via OpenRouter. Runs on your machine.
    </p>

    <!-- Badge -->
    <div class="badge mb-12">
      <span>🐻</span>
      Built at the School of Information, UC Berkeley
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-20">
      <button id="copy-btn" class="btn-primary flex items-center gap-2.5 text-base px-7 py-3">
        <code class="font-mono font-medium">pip install git+https://github.com/qazybekb/openmind.git</code>
        <svg class="w-4 h-4 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </button>
      <a href="https://github.com/qazybekb/openmind" target="_blank" class="btn-secondary text-base px-7 py-3">
        View on GitHub &rarr;
      </a>
    </div>

    <!-- Hero terminal -->
    <div class="terminal max-w-3xl mx-auto text-left shadow-2xl shadow-black/40 ring-1 ring-white/[0.03]">
      <div class="terminal-header">
        <div class="terminal-dot bg-[#ff5f57]"></div>
        <div class="terminal-dot bg-[#febc2e]"></div>
        <div class="terminal-dot bg-[#28c840]"></div>
        <span class="ml-3 text-xs text-text-muted font-sans">openmind</span>
      </div>
      <div class="terminal-body text-text-secondary text-[13px] md:text-sm">
        <div class="mb-3">
          <span class="text-text-muted">$</span> <span class="text-text-primary">openmind</span>
        </div>
        <div class="mb-5 text-text-secondary">
          &#x1f43b; Hey Oski! Go Bears! &#x1f499;&#x1f49b;
        </div>
        <div class="mb-4">
          <span class="text-text-muted">You &rarr;</span> <span class="text-text-primary">What's due this week?</span>
        </div>
        <div class="space-y-2 mb-5">
          <div>&#x1f525; <span class="text-text-primary font-medium">HIGH</span> &mdash; NLP midterm report <span class="text-text-muted">(due Fri, 30% of grade)</span></div>
          <div>&#x1f4cb; <span class="text-text-primary font-medium">MED</span>&ensp; &mdash; Social Issues writing prompt <span class="text-text-muted">(due Mon)</span></div>
          <div>&#x1f4da; <span class="text-text-primary font-medium">LOW</span>&ensp; &mdash; Finance case reading <span class="text-text-muted">(due next Wed)</span></div>
        </div>
        <div class="text-text-muted">
          I'd start with the NLP report &mdash; that's 30% of your grade and due in 3 days.<br/>
          You could knock out the outline at a Moffitt table tonight.
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 mt-16 text-sm text-text-muted">
      <div class="text-center">
        <div class="text-2xl font-bold text-text-primary">43</div>
        <div class="text-xs">tools</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-text-primary">11K</div>
        <div class="text-xs">courses indexed</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-text-primary">240</div>
        <div class="text-xs">departments</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-text-primary">0</div>
        <div class="text-xs">servers needed</div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('copy-btn')?.addEventListener('click', function() {
    const text = 'pip install git+https://github.com/qazybekb/openmind.git';
    const btn = this;
    const original = btn.innerHTML;

    function showCopied() {
      btn.innerHTML = '<code class="font-mono font-medium">Copied!</code> &check;';
      setTimeout(() => { btn.innerHTML = original; }, 1500);
    }

    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(showCopied);
    } else {
      // Fallback for HTTP
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showCopied();
    }
  });
</script>
