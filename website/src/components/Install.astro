---
---
<section id="install" class="section">
  <div class="container">
    <div class="text-center mb-16 fade-in">
      <div class="badge mb-5">Get started</div>
      <h2 class="text-3xl md:text-5xl font-bold text-text-primary tracking-tight mb-5">
        5 minutes to<br/><span class="text-cal-gold">your first question.</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        No Docker. No server. No signup. Three steps: bCourses token, pick a model, OpenRouter key. Done.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">

      <!-- Install command -->
      <div class="fade-in mb-12">
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dot bg-[#ff5f57]"></div>
            <div class="terminal-dot bg-[#febc2e]"></div>
            <div class="terminal-dot bg-[#28c840]"></div>
          </div>
          <div class="terminal-body text-[13px] md:text-sm space-y-1.5">
            <div><span class="text-text-secondary">$</span> <span class="text-text-primary">pip install git+https://github.com/qazybekb/openmind.git</span></div>
            <div><span class="text-text-secondary">$</span> <span class="text-text-primary">openmind</span></div>
            <div class="mt-3">
              &#x1f43b; Welcome to OpenMind! Go Bears! &#x1f499;&#x1f49b;
            </div>
            <div class="mt-2"><span class="text-text-primary">Step 1 of 3</span> &mdash; Connect to bCourses</div>
            <div>&ensp;<span class="text-text-secondary">bCourses token:</span> ********</div>
            <div>&ensp;<span class="text-text-muted">Key: 1072~****4T2r</span></div>
            <div>&ensp;<span class="text-green-500">Connected!</span> Hey Oski &#x1f43b;</div>
            <div>&ensp;<span class="text-green-500">6 courses</span> found</div>
            <div class="mt-2"><span class="text-text-primary">Step 2 of 3</span> &mdash; Choose your LLM</div>
            <div>&ensp;<span class="text-text-secondary">Enter 1, 2, 3, or a model ID (1):</span> <span class="text-text-primary">1</span></div>
            <div class="mt-2"><span class="text-text-primary">Step 3 of 3</span> &mdash; Connect OpenRouter</div>
            <div>&ensp;<span class="text-text-secondary">OpenRouter key:</span> ********</div>
            <div>&ensp;<span class="text-green-500">OK</span></div>
            <div class="mt-2">&#x1f389; <span class="text-text-primary">You're all set, Oski!</span> Go Bears!</div>
            <div class="mt-3">
              <span class="text-text-secondary">You &rarr;</span> <span class="text-text-primary">What's due this week?</span>
            </div>
          </div>
        </div>
      </div>

      <!-- What you need -->
      <div class="fade-in mb-12">
        <h3 class="text-sm font-semibold text-text-primary mb-5">What you need</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/guides/bcourses/" class="card group">
            <div class="text-lg mb-2">&#x1f4d8;</div>
            <h4 class="text-text-primary font-medium text-sm mb-1 group-hover:text-cal-gold transition-colors">bCourses token</h4>
            <p class="text-text-secondary text-xs">Profile &rarr; Settings &rarr; New Access Token</p>
          </a>
          <a href="/guides/openrouter/" class="card group">
            <div class="text-lg mb-2">&#x1f916;</div>
            <h4 class="text-text-primary font-medium text-sm mb-1 group-hover:text-cal-gold transition-colors">LLM model</h4>
            <p class="text-text-secondary text-xs">Gemini, MiMo, or Claude &mdash; your choice</p>
          </a>
          <a href="/guides/openrouter/" class="card group">
            <div class="text-lg mb-2">&#x1f511;</div>
            <h4 class="text-text-primary font-medium text-sm mb-1 group-hover:text-cal-gold transition-colors">OpenRouter key</h4>
            <p class="text-text-secondary text-xs">openrouter.ai/keys &mdash; free credits available</p>
          </a>
        </div>
        <p class="text-center text-text-muted text-xs mt-4">
          <a href="/guides/" class="underline underline-offset-2 hover:text-text-secondary">Step-by-step guides for each &rarr;</a>
        </p>
      </div>

      <!-- Add more later -->
      <div class="fade-in fade-in-delay-1 mb-12">
        <h3 class="text-sm font-semibold text-text-primary mb-5">Add more later</h3>
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dot bg-[#ff5f57]"></div>
            <div class="terminal-dot bg-[#febc2e]"></div>
            <div class="terminal-dot bg-[#28c840]"></div>
          </div>
          <div class="terminal-body text-[13px] space-y-1">
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup telegram</span> <span class="text-text-secondary">&ensp;# alerts on your phone</span></div>
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup profile</span> <span class="text-text-secondary">&ensp;&ensp;# personalize with goals + interests</span></div>
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup gmail</span> <span class="text-text-secondary">&ensp;&ensp;&ensp;# professor emails</span></div>
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup slack</span> <span class="text-text-secondary">&ensp;&ensp;&ensp;# course Slack channels</span></div>
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup calendar</span> <span class="text-text-secondary">&ensp;# Google Calendar sync</span></div>
            <div><span class="text-text-secondary">$</span> openmind <span class="text-text-primary">setup model</span> <span class="text-text-secondary">&ensp;&ensp;&ensp;# change your LLM model</span></div>
          </div>
        </div>
      </div>


    </div>
  </div>
</section>
