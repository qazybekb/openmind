---
---
<section id="install" class="section">
  <div class="container">
    <div class="text-center mb-16 fade-in">
      <div class="badge mb-5">Get started</div>
      <h2 class="text-3xl md:text-5xl font-bold text-text-primary tracking-tight mb-5">
        Two inputs.<br/><span class="text-cal-gold">Instant value.</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        No Docker. No server. No 21-question setup. Just your bCourses token and an AI key.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">

      <!-- Install command -->
      <div class="fade-in mb-12">
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dot bg-[#ff5f57]"></div>
            <div class="terminal-dot bg-[#febc2e]"></div>
            <div class="terminal-dot bg-[#28c840]"></div>
          </div>
          <div class="terminal-body text-[13px] md:text-sm space-y-1.5">
            <div><span class="text-text-muted">$</span> <span class="text-text-primary">pip install openmind</span></div>
            <div><span class="text-text-muted">$</span> <span class="text-text-primary">openmind</span></div>
            <div class="mt-3">
              &#x1f43b; Welcome to OpenMind! Go Bears! &#x1f499;&#x1f49b;
            </div>
            <div class="mt-2"><span class="text-text-primary">Step 1 of 2</span> &mdash; Connect to bCourses</div>
            <div>&ensp;<span class="text-text-muted">bCourses token:</span> &bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</div>
            <div>&ensp;<span class="text-green-500">Connected!</span> Hey Oski &#x1f43b;</div>
            <div>&ensp;<span class="text-green-500">6 courses</span> found</div>
            <div class="mt-2"><span class="text-text-primary">Step 2 of 2</span> &mdash; Connect an AI model</div>
            <div>&ensp;<span class="text-text-muted">OpenRouter key:</span> &bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;</div>
            <div>&ensp;<span class="text-green-500">OK</span></div>
            <div class="mt-2">&#x1f389; <span class="text-text-primary">You're ready!</span></div>
            <div class="mt-3">
              <span class="text-text-muted">You &rarr;</span> <span class="text-text-primary">What's due this week?</span>
            </div>
          </div>
        </div>
      </div>

      <!-- What you need -->
      <div class="fade-in mb-12">
        <h3 class="text-sm font-semibold text-text-primary mb-5">What you need</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="card">
            <div class="text-lg mb-2">&#x1f4d8;</div>
            <h4 class="text-text-primary font-medium text-sm mb-1">bCourses API token</h4>
            <p class="text-text-muted text-xs">Profile &rarr; Settings &rarr; New Access Token</p>
          </div>
          <div class="card">
            <div class="text-lg mb-2">&#x1f916;</div>
            <h4 class="text-text-primary font-medium text-sm mb-1">OpenRouter API key</h4>
            <p class="text-text-muted text-xs"><a href="https://openrouter.ai/keys" target="_blank" class="underline underline-offset-2 hover:text-text-secondary">openrouter.ai/keys</a> &mdash; free credits available</p>
          </div>
        </div>
      </div>

      <!-- Add more later -->
      <div class="fade-in fade-in-delay-1 mb-12">
        <h3 class="text-sm font-semibold text-text-primary mb-5">Add more later</h3>
        <div class="terminal">
          <div class="terminal-header">
            <div class="terminal-dot bg-[#ff5f57]"></div>
            <div class="terminal-dot bg-[#febc2e]"></div>
            <div class="terminal-dot bg-[#28c840]"></div>
          </div>
          <div class="terminal-body text-[13px] space-y-1">
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup telegram</span> <span class="text-text-muted">&ensp;# alerts on your phone</span></div>
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup profile</span> <span class="text-text-muted">&ensp;&ensp;# personalize with goals + resume</span></div>
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup gmail</span> <span class="text-text-muted">&ensp;&ensp;&ensp;# professor emails</span></div>
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup slack</span> <span class="text-text-muted">&ensp;&ensp;&ensp;# course Slack channels</span></div>
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup calendar</span> <span class="text-text-muted">&ensp;# Google Calendar sync</span></div>
            <div><span class="text-text-muted">$</span> openmind <span class="text-text-primary">setup model</span> <span class="text-text-muted">&ensp;&ensp;&ensp;# change your LLM model</span></div>
          </div>
        </div>
      </div>

      <!-- Privacy -->
      <div class="fade-in fade-in-delay-2">
        <div class="card border-border/50">
          <div class="flex items-start gap-4">
            <span class="text-2xl mt-0.5">&#x1f512;</span>
            <div>
              <h3 class="text-text-primary font-semibold mb-3">Private by design</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-xs text-text-muted">
                <div>&check; Runs on your laptop &mdash; no server</div>
                <div>&check; bCourses &amp; Gmail are read-only</div>
                <div>&check; API tokens never leave your machine</div>
                <div>&check; No analytics, no tracking, no telemetry</div>
                <div>&check; Profile stored locally at ~/.openmind/</div>
                <div>&check; Delete everything: <code class="text-text-secondary">rm -rf ~/.openmind</code></div>
              </div>
              <p class="text-xs text-text-muted mt-3">
                Run <code class="text-text-secondary">openmind privacy</code> to see exactly what stays local vs what goes to the LLM.
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
