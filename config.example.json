{
  "providers": {
    "gemini": {
      "apiKey": "YOUR_GEMINI_API_KEY"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": ["YOUR_TELEGRAM_USER_ID"]
    }
  },
  "agents": {
    "defaults": {
      "model": "gemini-2.5-pro",
      "provider": "gemini"
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": true,
      "interval_s": 10800
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "duckduckgo"
      }
    },
    "mcp_servers": {
      "todoist": {
        "command": "npx",
        "args": ["-y", "@shayonpal/mcp-todoist"],
        "env": {
          "TODOIST_API_TOKEN": "YOUR_TODOIST_API_TOKEN"
        }
      },
      "obsidian": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/root/obsidian"]
      },
      "playwright": {
        "command": "npx",
        "args": ["-y", "@playwright/mcp@latest"]
      },
      "gmail": {
        "command": "npx",
        "args": ["-y", "@shinzolabs/gmail-mcp"]
      }
    }
  }
}
